# Database connection settings
DATABASE_URL="postgresql://postgres:password123@localhost:5432/launchpad?schema=public"

# Redis cache and real-time pubsub settings
REDIS_URL="redis://localhost:6379"

# MinIO (S3 compatible) Storage settings
MINIO_ENDPOINT="localhost"
MINIO_PORT=9000
MINIO_ACCESS_KEY="minioadmin"
MINIO_SECRET_KEY="minioadminpassword"

# Keycloak OpenID Connect authentication settings
KEYCLOAK_REALM="launchpad"
KEYCLOAK_AUTH_SERVER_URL="http://localhost:8080"
KEYCLOAK_CLIENT_ID="launchpad-gateway"

# AI Copilot & Validator configuration
OPENAI_API_KEY="your-openai-api-key-here"
