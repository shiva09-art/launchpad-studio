{
  "name": "launchpad",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "services/*"
  ],
  "scripts": {
    "dev:web": "npm run dev -w apps/web",
    "dev:server": "npm run start:dev -w services/server",
    "build:web": "npm run build -w apps/web",
    "build:server": "npm run build -w services/server"
  }
}
